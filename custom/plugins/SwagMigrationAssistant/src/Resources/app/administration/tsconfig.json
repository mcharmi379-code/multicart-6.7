{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "es2020",
    "lib": [
      "ES2020",
      "DOM"
    ],
    "module": "commonjs",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "paths": {
